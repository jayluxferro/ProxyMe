<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/colorSurface"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_handle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="@string/qr_share_title"
        android:textColor="@color/colorOnSurface"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/qr_config_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:textColor="@color/colorOnBackground"
        android:textSize="14sp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <ImageView
            android:id="@+id/qr_image"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:padding="12dp"
            android:contentDescription="@string/qr_share_title" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:gravity="center"
        android:text="@string/qr_share_hint"
        android:textColor="@color/colorOnBackground"
        android:textSize="13sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_share_qr"
        style="@style/Widget.ProxyMe.Button.Connect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_share" />

</LinearLayout>
