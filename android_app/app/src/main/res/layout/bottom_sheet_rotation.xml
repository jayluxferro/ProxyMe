<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_handle" />

        <!-- Title + toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/rotation_title"
                android:textColor="@color/colorOnSurface"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/rotation_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/colorSecondary"
                app:trackTintMode="src_atop" />

        </LinearLayout>

        <!-- Settings area -->
        <LinearLayout
            android:id="@+id/rotation_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Interval -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.1"
                android:text="@string/rotation_interval_label"
                android:textAllCaps="true"
                android:textColor="@color/colorOnBackground"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/rotation_interval_spinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:background="@color/colorInputBackground"
                android:padding="12dp"
                android:popupBackground="@color/colorSurface" />

            <!-- Rotation order label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.1"
                android:text="@string/rotation_order_label"
                android:textAllCaps="true"
                android:textColor="@color/colorOnBackground"
                android:textSize="12sp" />

            <!-- Config list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rotation_config_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:nestedScrollingEnabled="false" />

            <!-- Empty state -->
            <TextView
                android:id="@+id/rotation_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="24dp"
                android:text="@string/rotation_empty"
                android:textColor="@color/colorOnBackground"
                android:textSize="14sp" />

            <!-- Add button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_to_rotation"
                style="@style/Widget.ProxyMe.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/rotation_add_config"
                android:textSize="13sp"
                app:icon="@android:drawable/ic_input_add"
                app:iconSize="16dp"
                app:iconTint="@color/colorSecondary" />

            <!-- Status -->
            <TextView
                android:id="@+id/rotation_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textColor="@color/colorOnBackground"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
